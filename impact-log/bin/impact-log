#!/usr/bin/env bash
set -euo pipefail

IMPACT_LOG_HOME="${IMPACT_LOG_HOME:-$HOME/.claude/impact-log}"
EVENTS="$IMPACT_LOG_HOME/events.jsonl"
STATE="$IMPACT_LOG_HOME/state.json"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGIN_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
TEMPLATES="$PLUGIN_ROOT/templates"

usage() {
  cat <<'EOF'
impact-log — ambient work-evidence capture for Claude Code

Usage:
  impact-log init                 One-time setup (creates the local log store)
  impact-log status               Show capture status and recent activity
  impact-log weekly [--since D]   Synthesize a weekly report from captured events
  impact-log quarterly            Roll up this quarter's weekly reports
  impact-log needs-context        List low-confidence entries needing manual context
EOF
}

cmd_init() {
  mkdir -p "$IMPACT_LOG_HOME/reports/weekly" "$IMPACT_LOG_HOME/reports/quarterly"
  [ -f "$EVENTS" ] || : > "$EVENTS"
  [ -f "$STATE" ] || echo '{"enabled":true,"event_count":0,"last_event_ts":null}' > "$STATE"
  echo "impact-log initialized at $IMPACT_LOG_HOME"
  echo
  echo "Optional — show capture status in your statusline by adding to settings.json:"
  echo '  "statusLine": { "type": "command", "command": "'"$PLUGIN_ROOT"'/statusline/impact-log-status.sh" }'
}

cmd_status() {
  if ! command -v jq >/dev/null 2>&1; then
    echo "impact-log: jq not found — capture is disabled until jq is installed."
    exit 0
  fi
  if [ ! -f "$STATE" ]; then
    echo "impact-log: not initialized. Run 'impact-log init'."
    exit 0
  fi
  local count last today today_count
  count=$(jq -r '.event_count // 0' "$STATE")
  last=$(jq -r '.last_event_ts // "never"' "$STATE")
  today=$(date -u +%Y-%m-%d)
  today_count=0
  if [ -f "$EVENTS" ]; then
    today_count=$(grep -c "\"ts\":\"$today" "$EVENTS" 2>/dev/null || true)
    today_count=${today_count:-0}
  fi
  echo "impact-log: enabled"
  echo "  events captured (all-time): $count"
  echo "  events captured (today):    $today_count"
  echo "  last event:                 $last"
  echo "  store:                      $EVENTS"
}

repo_window_summary() {
  local dir="$1" since="$2"
  [ -d "$dir/.git" ] || return 0
  echo "### $(git -C "$dir" remote get-url origin 2>/dev/null || echo "$dir") ($(git -C "$dir" branch --show-current 2>/dev/null))"
  git -C "$dir" log --since="$since" --pretty='- %ad %s' --date=short 2>/dev/null || true
  if command -v gh >/dev/null 2>&1; then
    (cd "$dir" && gh pr list --state merged --search "merged:>=$since" --json title,url --jq '.[] | "- PR: " + .title + " (" + .url + ")"' 2>/dev/null) || true
  fi
}

cmd_weekly() {
  local since
  since=$(date -u -v-7d +%Y-%m-%d 2>/dev/null || date -u -d '7 days ago' +%Y-%m-%d)
  while [ $# -gt 0 ]; do
    case "$1" in
      --since) since="$2"; shift 2 ;;
      *) shift ;;
    esac
  done
  [ -f "$EVENTS" ] || { echo "No events captured yet."; exit 0; }

  local dirs evidence low_conf week_label out template
  dirs=$(jq -r --arg since "$since" 'select(.ts >= $since) | .cwd' "$EVENTS" | sort -u)

  evidence=""
  for d in $dirs; do
    evidence="$evidence
$(repo_window_summary "$d" "$since")"
  done

  low_conf=$(jq -r --arg since "$since" 'select(.ts >= $since and .confidence == "low") | "- " + .event + " at " + .ts + " (cwd: " + .cwd + ")"' "$EVENTS")

  week_label=$(date -u +%G-W%V)
  out="$IMPACT_LOG_HOME/reports/weekly/$week_label.md"
  mkdir -p "$(dirname "$out")"
  template=$(cat "$TEMPLATES/weekly.md")

  {
    echo "$template"
    echo
    echo "## Raw evidence ($since to now)"
    echo "$evidence"
    if [ -n "$low_conf" ]; then
      echo
      echo "## Needs context (low confidence)"
      echo "$low_conf"
    fi
  } | claude -p "Fill in this weekly reflection template using only the raw evidence and git/PR history provided below it. Be concrete and specific (repos, commits, PRs). Do not invent work that isn't evidenced. Keep a 'Needs context' section listing anything you couldn't confidently attribute." > "$out"

  echo "Wrote $out"
}

cmd_quarterly() {
  local quarter_label weekly_dir out template
  quarter_label=$(date -u +%G-Q$(( ( $(date -u +%-m) - 1) / 3 + 1 )))
  weekly_dir="$IMPACT_LOG_HOME/reports/weekly"
  out="$IMPACT_LOG_HOME/reports/quarterly/$quarter_label.md"
  mkdir -p "$(dirname "$out")"
  template=$(cat "$TEMPLATES/quarterly.md")

  {
    echo "$template"
    echo
    echo "## Weekly reports this quarter"
    for f in "$weekly_dir"/*.md; do
      [ -f "$f" ] || continue
      echo "---"
      cat "$f"
    done
  } | claude -p "Synthesize these weekly reports into a quarterly summary organized by theme and impact, suitable as raw material for a performance review. Do not invent work not present in the source material." > "$out"

  echo "Wrote $out"
}

cmd_needs_context() {
  [ -f "$EVENTS" ] || { echo "No events captured yet."; exit 0; }
  jq -r 'select(.confidence == "low") | "- " + .ts + " " + .event + " (cwd: " + .cwd + ")"' "$EVENTS"
}

case "${1:-}" in
  init) cmd_init ;;
  status) cmd_status ;;
  weekly) shift; cmd_weekly "$@" ;;
  quarterly) cmd_quarterly ;;
  needs-context) cmd_needs_context ;;
  *) usage ;;
esac
